# Copy this file to ".env" and fill in your real values.
# NEVER commit the actual ".env" file to git — it's already in .gitignore.

# Your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=paste_your_key_here

# Port the backend server runs on
PORT=3001

# In production, set this to your deployed frontend's exact URL
# (e.g. https://your-app.vercel.app) to lock down CORS.
# Leave as * only for local development.
FRONTEND_ORIGIN=*
